# Copy to .env and fill in. Loaded by `azd ai agent run` / `azd ai agent invoke --local`.
# Foundry project endpoint (Foundry portal > Project > Overview > Endpoint).
FOUNDRY_PROJECT_ENDPOINT=https://<project>.services.ai.azure.com/api/projects/<project>

# Chat model deployment name in the Foundry project (e.g. gpt-4.1-mini, gpt-4o).
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# SharePoint tenant host used to build the UPS root site URL (https://<host>).
SHAREPOINT_TENANT_HOSTNAME=mngenv168112.sharepoint.com

# Optional: full root site URL override (takes precedence over the hostname above).
# SHAREPOINT_ROOT_SITE_URL=https://mngenv168112.sharepoint.com

# Optional: local server port (azd ai agent run defaults to 8088).
# PORT=8088

# ---- FAQ / Q&A search tool (local, in-process; no OBO) ----
# Azure AI Search service that hosts the faq-index. The agent queries it with its OWN identity,
# filtering by the user's country (the index 'Location' field). Omit AZURE_SEARCH_ENDPOINT to
# disable the tool. Prefer Managed Identity (grant the agent the 'Search Index Data Reader' role
# and leave AZURE_SEARCH_API_KEY blank); a read-only query key is supported for quick local runs.
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
AZURE_SEARCH_INDEX_NAME=faq-index
AZURE_SEARCH_COUNTRY_FIELD=Location
# AZURE_SEARCH_API_KEY=<read-only-query-key>      # leave blank to use Managed Identity / DefaultAzureCredential
# AZURE_SEARCH_INCLUDE_GLOBAL=true                # also return Location='Global' entries (default true)
