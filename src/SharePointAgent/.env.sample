# Copy to .env and fill in. Loaded by `azd ai agent run` / `azd ai agent invoke --local`.
# Foundry project endpoint (Foundry portal > Project > Overview > Endpoint).
FOUNDRY_PROJECT_ENDPOINT=https://<project>.services.ai.azure.com/api/projects/<project>

# Chat model deployment name in the Foundry project (e.g. gpt-4.1-mini, gpt-4o).
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# SharePoint tenant host used to build the UPS root site URL (https://<host>).
SHAREPOINT_TENANT_HOSTNAME=mngenv168112.sharepoint.com

# Optional: full root site URL override (takes precedence over the hostname above).
# SHAREPOINT_ROOT_SITE_URL=https://mngenv168112.sharepoint.com

# Optional: local server port (azd ai agent run defaults to 8088).
# PORT=8088
