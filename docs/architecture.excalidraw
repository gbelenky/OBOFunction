{
  "type": "excalidraw",
  "version": 2,
  "source": "claude",
  "appState": { "viewBackgroundColor": "#ffffff" },
  "elements": [
    {
      "type": "text", "id": "title", "x": 40, "y": 20, "width": 900, "height": 40,
      "text": "OBOFunction — SharePoint profile to Foundry agent, signed-in user identity end-to-end (OBO)",
      "fontSize": 20, "fontFamily": 2, "strokeColor": "#000000",
      "textAlign": "left", "verticalAlign": "top"
    },

    { "type": "rectangle", "id": "spfx", "x": 380, "y": 90, "width": 320, "height": 90,
      "strokeColor": "#0078D4", "backgroundColor": "#CFE4FA", "fillStyle": "solid",
      "strokeWidth": 2, "roundness": { "type": 3 },
      "boundElements": [{ "type": "text", "id": "spfx_t" }] },
    { "type": "text", "id": "spfx_t", "containerId": "spfx", "x": 390, "y": 110, "width": 300, "height": 50,
      "text": "SPFx web part (SharePoint)\nAadHttpClient -> user JWT (aud api://proxy)",
      "fontSize": 14, "fontFamily": 2, "strokeColor": "#000000", "textAlign": "center", "verticalAlign": "middle" },

    { "type": "rectangle", "id": "proxy", "x": 380, "y": 300, "width": 320, "height": 110,
      "strokeColor": "#107C10", "backgroundColor": "#DFF6DD", "fillStyle": "solid",
      "strokeWidth": 2, "roundness": { "type": 3 },
      "boundElements": [{ "type": "text", "id": "proxy_t" }] },
    { "type": "text", "id": "proxy_t", "containerId": "proxy", "x": 390, "y": 320, "width": 300, "height": 70,
      "text": "Proxy  (src/OBOFunction, App Service .NET 8)\nPOST /api/agent/chat\nvalidates JWT, OBO to MCP audience, delegates to agent",
      "fontSize": 13, "fontFamily": 2, "strokeColor": "#000000", "textAlign": "center", "verticalAlign": "middle" },

    { "type": "rectangle", "id": "foundry", "x": 380, "y": 510, "width": 320, "height": 100,
      "strokeColor": "#5C2D91", "backgroundColor": "#E8DAEF", "fillStyle": "solid",
      "strokeWidth": 2, "roundness": { "type": 3 },
      "boundElements": [{ "type": "text", "id": "foundry_t" }] },
    { "type": "text", "id": "foundry_t", "containerId": "foundry", "x": 390, "y": 530, "width": 300, "height": 60,
      "text": "Foundry model Responses (gpt-4.1-mini)\nleg 1: proxy app token authorizes the call\nleg 2: mcp tool carries per-user MCP token",
      "fontSize": 12, "fontFamily": 2, "strokeColor": "#000000", "textAlign": "center", "verticalAlign": "middle" },

    { "type": "rectangle", "id": "mcp", "x": 380, "y": 680, "width": 320, "height": 90,
      "strokeColor": "#F7630C", "backgroundColor": "#FFF4CE", "fillStyle": "solid",
      "strokeWidth": 2, "roundness": { "type": 3 },
      "boundElements": [{ "type": "text", "id": "mcp_t" }] },
    { "type": "text", "id": "mcp_t", "containerId": "mcp", "x": 390, "y": 700, "width": 300, "height": 50,
      "text": "SharePointMcp  (src/SharePointMcp, App Service)\nget_sharepoint_profile tool, OBO as the user",
      "fontSize": 13, "fontFamily": 2, "strokeColor": "#000000", "textAlign": "center", "verticalAlign": "middle" },

    { "type": "rectangle", "id": "graph2", "x": 770, "y": 685, "width": 300, "height": 80,
      "strokeColor": "#0c8599", "backgroundColor": "#99e9f2", "fillStyle": "solid",
      "strokeWidth": 2, "roundness": { "type": 3 },
      "boundElements": [{ "type": "text", "id": "graph2_t" }] },
    { "type": "text", "id": "graph2_t", "containerId": "graph2", "x": 780, "y": 705, "width": 280, "height": 40,
      "text": "Graph + SharePoint UPS\n(as the signed-in user)",
      "fontSize": 13, "fontFamily": 2, "strokeColor": "#000000", "textAlign": "center", "verticalAlign": "middle" },

    { "type": "rectangle", "id": "agent", "x": 30, "y": 505, "width": 300, "height": 110,
      "strokeColor": "#495057", "backgroundColor": "#dee2e6", "fillStyle": "solid",
      "strokeWidth": 2, "roundness": { "type": 3 },
      "boundElements": [{ "type": "text", "id": "agent_t" }] },
    { "type": "text", "id": "agent_t", "containerId": "agent", "x": 40, "y": 525, "width": 280, "height": 70,
      "text": "Foundry Hosted Agent\n(src/SharePointAgent, .NET 10)\nPlayground / autonomous demo.\nHostedMcpServerTool -> MCP server.",
      "fontSize": 12, "fontFamily": 2, "strokeColor": "#000000", "textAlign": "center", "verticalAlign": "middle" },

    { "type": "arrow", "id": "a_chat", "x": 540, "y": 180, "width": 0, "height": 118,
      "strokeColor": "#5C2D91", "strokeWidth": 2, "points": [[0,0],[0,118]],
      "startBinding": { "elementId": "spfx", "focus": 0, "gap": 2 },
      "endBinding": { "elementId": "proxy", "focus": 0, "gap": 2 } },
    { "type": "text", "id": "a_chat_t", "x": 600, "y": 215, "width": 250, "height": 40,
      "text": "POST /api/agent/chat\nAuthorization: Bearer <user JWT>",
      "fontSize": 12, "fontFamily": 2, "strokeColor": "#000000", "textAlign": "left", "verticalAlign": "top" },

    { "type": "arrow", "id": "a_resp", "x": 540, "y": 410, "width": 0, "height": 96,
      "strokeColor": "#5C2D91", "strokeWidth": 2, "points": [[0,0],[0,96]],
      "startBinding": { "elementId": "proxy", "focus": 0, "gap": 2 },
      "endBinding": { "elementId": "foundry", "focus": 0, "gap": 2 } },

    { "type": "arrow", "id": "a_fwd", "x": 540, "y": 610, "width": 0, "height": 66,
      "strokeColor": "#F7630C", "strokeWidth": 2, "points": [[0,0],[0,66]],
      "startBinding": { "elementId": "foundry", "focus": 0, "gap": 2 },
      "endBinding": { "elementId": "mcp", "focus": 0, "gap": 2 } },
    { "type": "text", "id": "a_fwd_t", "x": 555, "y": 632, "width": 250, "height": 25,
      "text": "Foundry forwards per-user token",
      "fontSize": 11, "fontFamily": 2, "strokeColor": "#000000", "textAlign": "left", "verticalAlign": "top" },

    { "type": "arrow", "id": "a_obo2", "x": 700, "y": 725, "width": 66, "height": 0,
      "strokeColor": "#0c8599", "strokeWidth": 2, "points": [[0,0],[66,0]],
      "startBinding": { "elementId": "mcp", "focus": 0, "gap": 2 },
      "endBinding": { "elementId": "graph2", "focus": 0, "gap": 2 } },
    { "type": "text", "id": "a_obo2_t", "x": 700, "y": 655, "width": 70, "height": 25,
      "text": "OBO",
      "fontSize": 12, "fontFamily": 2, "strokeColor": "#000000", "textAlign": "center", "verticalAlign": "top" },

    { "type": "arrow", "id": "a_agentmcp", "x": 330, "y": 600, "width": 110, "height": 110,
      "strokeColor": "#495057", "strokeWidth": 2, "strokeStyle": "dashed",
      "points": [[0,0],[110,110]],
      "startBinding": { "elementId": "agent", "focus": 0, "gap": 2 },
      "endBinding": { "elementId": "mcp", "focus": 0, "gap": 2 } },

    { "type": "rectangle", "id": "appregs", "x": 30, "y": 90, "width": 320, "height": 150,
      "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "roundness": { "type": 3 } },
    { "type": "text", "id": "appregs_t", "x": 45, "y": 100, "width": 295, "height": 135,
      "text": "Two app registrations only:\n1) Proxy API  api://<proxy-app>\n    scope access_as_user; OBO to\n    the MCP audience only.\n2) MCP API  api://<mcp-app>\n    scope access_as_user; OBO to\n    Graph/SharePoint as the user.",
      "fontSize": 12, "fontFamily": 2, "strokeColor": "#000000", "textAlign": "left", "verticalAlign": "top" }
  ]
}
