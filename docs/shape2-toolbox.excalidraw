      "strokeWidth": 2,
      "points": [[0, 0], [0, 41]],
      "startBinding": { "elementId": "mcp", "focus": 0, "gap": 2 },
      "endBinding": { "elementId": "graph", "focus": 0, "gap": 2 }
    },
