{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build proxy",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/OBOFunction"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run proxy",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/OBOFunction/OBOFunction.csproj"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/OBOFunction"
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
